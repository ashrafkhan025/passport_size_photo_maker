PORT=5000
NODE_ENV=development

# Frontend URL allowed by CORS
CLIENT_URL=http://localhost:5173

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/passport_photo_app

# remove.bg or compatible background-removal API key
BG_REMOVE_API_KEY=your_api_key

# Optional, useful for local development if you switch providers
BG_REMOVE_API_URL=https://api.remove.bg/v1.0/removebg

# Public URL for static image links returned by the API
SERVER_URL=http://localhost:5000

# Upload limits
MAX_FILE_SIZE_MB=10
